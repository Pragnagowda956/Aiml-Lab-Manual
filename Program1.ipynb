    "import copy\n",
    "\n",
    "class CoastState:\n",
    "    def __init__(self, c, m):\n",
    "        self.cannibals = c\n",
    "        self.missionaries = m\n",
    "\n",
    "    # Check if missionaries are not outnumbered\n",
    "    def valid_coast(self):\n",
    "        if self.missionaries >= self.cannibals or self.missionaries == 0:\n",
    "            return True\n",
    "        return False\n",
    "\n",
    "    # Goal state: all on right side\n",
    "    def goal_coast(self):\n",
    "        if self.cannibals == 3 and self.missionaries == 3:\n",
    "            return True\n",
    "        return False\n",
    "\n",
    "\n",
    "class GameState:\n",
    "    def __init__(self, data):\n",
    "        self.data = data\n",
    "        self.parent = None\n",
    "\n",
    "    # Generate children states\n",
    "    def building_tree(self):\n",
    "        children = []\n",
    "\n",
    "        if self.data[\"boat\"] == \"left\":\n",
    "            coast = \"left\"\n",
    "            across_coast = \"right\"\n",
    "        else:\n",
    "            coast = \"right\"\n",
    "            across_coast = \"left\"\n",
    "\n",
    "        temp = copy.deepcopy(self.data)\n",
    "\n",
    "        # Move 2 Cannibals (CC)\n",
    "        if temp[coast].cannibals >= 2:\n",
    "            temp[coast].cannibals -= 2\n",
    "            temp[across_coast].cannibals += 2\n",
    "            temp[\"boat\"] = across_coast\n",
    "\n",
    "            if temp[coast].valid_coast() and temp[across_coast].valid_coast():\n",
    "                child = GameState(temp)\n",
    "                child.parent = self\n",
    "                children.append(child)\n",
    "\n",
    "        temp = copy.deepcopy(self.data)\n",
    "\n",
    "        # Move 2 Missionaries (MM)\n",
    "        if temp[coast].missionaries >= 2:\n",
    "            temp[coast].missionaries -= 2\n",
    "            temp[across_coast].missionaries += 2\n",
    "            temp[\"boat\"] = across_coast\n",
    "\n",
    "            if temp[coast].valid_coast() and temp[across_coast].valid_coast():\n",
    "                child = GameState(temp)\n",
    "                child.parent = self\n",
    "                children.append(child)\n",
    "\n",
    "        temp = copy.deepcopy(self.data)\n",
    "\n",
    "        # Move 1 Cannibal (C)\n",
    "        if temp[coast].cannibals >= 1:\n",
    "            temp[coast].cannibals -= 1\n",
    "            temp[across_coast].cannibals += 1\n",
    "            temp[\"boat\"] = across_coast\n",
    "\n",
    "            if temp[coast].valid_coast() and temp[across_coast].valid_coast():\n",
    "                child = GameState(temp)\n",
    "                child.parent = self\n",
    "                children.append(child)\n",
    "\n",
    "        temp = copy.deepcopy(self.data)\n",
    "\n",
    "        # Move 1 Missionary (M)\n",
    "        if temp[coast].missionaries >= 1:\n",
    "            temp[coast].missionaries -= 1\n",
    "            temp[across_coast].missionaries += 1\n",
    "            temp[\"boat\"] = across_coast\n",
    "\n",
    "            if temp[coast].valid_coast() and temp[across_coast].valid_coast():\n",
    "                child = GameState(temp)\n",
    "                child.parent = self\n",
    "                children.append(child)\n",
    "\n",
    "        temp = copy.deepcopy(self.data)\n",
    "\n",
    "        # Move 1 Cannibal and 1 Missionary (CM)\n",
    "        if temp[coast].missionaries >= 1 and temp[coast].cannibals >= 1:\n",
    "            temp[coast].missionaries -= 1\n",
    "            temp[across_coast].missionaries += 1\n",
    "            temp[coast].cannibals -= 1\n",
    "            temp[across_coast].cannibals += 1\n",
    "            temp[\"boat\"] = across_coast\n",
    "\n",
    "            if temp[coast].valid_coast() and temp[across_coast].valid_coast():\n",
    "                child = GameState(temp)\n",
    "                child.parent = self\n",
    "                children.append(child)\n",
    "\n",
    "        return children\n",
    "\n",
    "    # Breadth First Search\n",
    "    def breadth_first_search(self):\n",
    "\n",
    "        left = CoastState(3, 3)\n",
    "        right = CoastState(0, 0)\n",
    "\n",
    "        root_data = {\"left\": left, \"right\": right, \"boat\": \"left\"}\n",
    "\n",
    "        explored = []\n",
    "        nodes = []\n",
    "\n",
    "        nodes.append(GameState(root_data))\n",
    "\n",
    "        while len(nodes) > 0:\n",
    "\n",
    "            g = nodes.pop(0)\n",
    "            explored.append(g)\n",
    "\n",
    "            if g.data[\"right\"].goal_coast():\n",
    "                return g\n",
    "\n",
    "            else:\n",
    "                next_children = g.building_tree()\n",
    "\n",
    "                for x in next_children:\n",
    "                    if (x not in nodes) and (x not in explored):\n",
    "                        nodes.append(x)\n",
    "\n",
    "        return None\n",
    "\n",
    "    # Print solution path\n",
    "    def print_path(self, g):\n",
    "\n",
    "        path = [g]\n",
    "\n",
    "        while g.parent:\n",
    "            g = g.parent\n",
    "            path.append(g)\n",
    "\n",
    "        print(\"Left Side | Right Side | Boat\")\n",
    "        print(\"C M | C M | Position\")\n",
    "\n",
    "        counter = 0\n",
    "\n",
    "        for p in reversed(path):\n",
    "            print(\n",
    "                \"State\", counter,\n",
    "                \"| Left C:\", p.data[\"left\"].cannibals,\n",
    "                \"Left M:\", p.data[\"left\"].missionaries,\n",
    "                \"| Right C:\", p.data[\"right\"].cannibals,\n",
    "                \"Right M:\", p.data[\"right\"].missionaries,\n",
    "                \"| Boat:\", p.data[\"boat\"]\n",
    "            )\n",
    "            counter += 1\n",
    "\n",
    "        print(\"End of Path!\")\n",
    "\n",
    "    def main(self):\n",
    "\n",
    "        solution = self.breadth_first_search()\n",
    "\n",
    "        print(\"Missionaries and Cannibals AI Problem Solution using Breadth First Search:\")\n",
    "        self.print_path(solution)\n",
    "\n",
    "if __name__ == \"__main__\":\n",
    "    mc = GameState(None)\n",
    "    mc.main()"
   ]
