    "    'C': [[('J', 1)]],\n",
    "    'D': [[('E', 1), ('F', 1)]],\n",
    "    'G': [[('T', 1)]] # Corrected 'T' in quotes\n",
    "}\n",
    "G1 = Graph(graph1, h1, 'A')\n",
    "G1.applyAOStar()\n",
    "G1.printSolution()\n",
    "\n",
    "# Graph 2\n",
    "print(\"Graph - 2\")\n",
    "h2 = {'A': 1, 'B': 6, 'C': 12, 'D': 10, 'E': 4, 'F': 4, 'G': 5, 'H': 7}\n",
