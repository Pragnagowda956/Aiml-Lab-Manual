    "import queue\n",
    "import time\n",
    "import random\n",
    "# Global variables for capacities\n",
    "maxjug1 = 0\n",
    "maxjug2 = 0\n",
    "visitednodelist = []\n",
    "\n",
    "class node:\n",
    "    def __init__(self, parent):\n",
    "        self.x = 0\n",
    "        self.y = 0\n",
    "        self.parent = parent\n",
    "\n",
    "    def printnode(self):\n",
    "        print(\"(\", self.x, \",\", self.y, \")\")\n",
    "\n",
    "    def generateAllSuccessors(self, cnode):\n",
    "        list1 = []\n",
    "        list_rule = []\n",
    "        # Try all 8 rules in random order\n",
    "        while len(list_rule) < 8:\n",
    "            rule_no = random.randint(1, 8)\n",
    "            if (not rule_no in list_rule):\n",
    "                list_rule.append(rule_no)\n",
    "                nextnode = self.operation(cnode, rule_no)\n",
    "                if nextnode != None and not self.IsNodeInlist(nextnode, visitednodelist):\n",
    "                    list1.append(nextnode)\n",
    "        return list1\n",
    "\n",
    "    def operation(self, cnode, rule):\n",
    "        x = cnode.x\n",
    "        y = cnode.y\n",
    "        \n",
    "        # Rule 1: Fill Jug 1\n",
    "        if rule == 1:\n",
    "            x = maxjug1\n",
    "        # Rule 2: Fill Jug 2\n",
    "        elif rule == 2:\n",
    "            y = maxjug2\n",
    "        # Rule 3: Empty Jug 1\n",
    "        elif rule == 3:\n",
    "            x = 0\n",
    "        # Rule 4: Empty Jug 2\n",
    "        elif rule == 4:\n",
    "            y = 0\n",
    "        # Rule 5: Pour Jug 2 to Jug 1\n",
    "        elif rule == 5:\n",
    "            if x + y >= maxjug1:\n",
    "                y = y - (maxjug1 - x)\n",
    "                x = maxjug1\n",
    "            else:\n",
    "                x = x + y\n",
    "                y = 0\n",
    "        # Rule 6: Pour Jug 1 to Jug 2\n",
    "        elif rule == 6:\n",
    "            if x + y >= maxjug2:\n",
    "                x = x - (maxjug2 - y)\n",
    "                y = maxjug2\n",
    "            else:\n",
    "                y = x + y\n",
    "                x = 0\n",
    "        # Rule 7: Pour all from 2 to 1 (if it fits)\n",
    "        elif rule == 7:\n",
    "            if x + y <= maxjug1:\n",
    "                x = x + y\n",
    "                y = 0\n",
    "            else:\n",
    "                return None\n",
    "        # Rule 8: Pour all from 1 to 2 (if it fits)\n",
    "        elif rule == 8:\n",
    "            if x + y <= maxjug2:\n",
    "                y = x + y\n",
    "                x = 0\n",
    "            else:\n",
    "                return None\n",
    "\n",
    "        if (x == cnode.x and y == cnode.y):\n",
    "            return None\n",
    "            \n",
    "        nextnode = node(cnode)\n",
    "        nextnode.x = x\n",
    "        nextnode.y = y\n",
    "        return nextnode\n",
    "\n",
    "    def IsNodeInlist(self, cnode, list1):\n",
    "        for m in list1:\n",
    "            if (cnode.x == m.x and cnode.y == m.y):\n",
    "                return True\n",
    "        return False\n",
    "\n",
    "    def dfsMain(self, initialNode, GoalNode):\n",
    "        stack = [] # Using a list as a stack for DFS\n",
    "        stack.append(initialNode)\n",
    "        \n",
    "        while len(stack) > 0:\n",
    "            cnode = stack.pop()\n",
    "            visitednodelist.append(cnode)\n",
    "            \n",
    "            print(\"Visiting node:\", end=\" \")\n",
    "            cnode.printnode()\n",
    "            \n",
    "            if self.isGoalNode(cnode, GoalNode):\n",
    "                return cnode\n",
    "            \n",
    "            successor_nodes = self.generateAllSuccessors(cnode)\n",
    "            for child in successor_nodes:\n",
    "                if not self.IsNodeInlist(child, visitednodelist):\n",
    "                    stack.append(child)\n",
    "        return None\n",
    "\n",
    "    def isGoalNode(self, cnode, gnode):\n",
    "        # Goal check: either jug1 has target, or jug2 has target\n",
    "        if (cnode.x == gnode.x or cnode.y == gnode.x):\n",
    "            return True\n",
    "        return False\n",
    "\n",
    "    def printpath(self, cnode):\n",
    "        path = []\n",
    "        temp = cnode\n",
    "        while (temp != None):\n",
    "            path.append(temp)\n",
    "            temp = temp.parent\n",
    "        path.reverse()\n",
    "        print(\"\\nPath Found:\")\n",
    "        for i in path:\n",
    "            i.printnode()\n",
    "        print(\"Path Cost (steps):\", len(path) - 1)\n",
    "\n",
    "if __name__ == '__main__':\n",
    "    # Input\n",
    "    maxjug1 = int(input(\"Enter value of maxjug1: \"))\n",
    "    maxjug2 = int(input(\"Enter value of maxjug2: \"))\n",
    "    goal = int(input(\"Enter value of Goal in either jug: \"))\n",
    "    \n",
    "    initialNode = node(None)\n",
    "    initialNode.x = 0\n",
    "    initialNode.y = 0\n",
    "    \n",
    "    GoalNode = node(None)\n",
    "    GoalNode.x = goal # Using goal to represent target in either jug\n",
    "\n",
    "    start_time = time.time()\n",
    "    \n",
    "    solver = node(None)\n",
    "    solutionNode = solver.dfsMain(initialNode, GoalNode)\n",
    "    \n",
    "    end_time = time.time()\n",
    "    \n",
    "    if (solutionNode != None):\n",
    "        print(\"\\nSolution Found!\")\n",
    "        solver.printpath(solutionNode)\n",
    "    else:\n",
    "        print(\"\\nSolution can't be found.\")\n",
    "        \n",
    "    diff = end_time - start_time\n",
    "    print(\"Execution Time: {:.4f} ms\".format(diff * 1000))\n"
   ]
