    "    def h(self, n):\n",
    "        H = {'A': 1, 'C': 1, 'B': 1, 'D': 1}\n",
    "        return H.get(n, 0)\n",
    "\n",
    "    def a_star_algorithm(self, start, stop):\n",
    "        open_lst = set([start])\n",
    "        closed_lst = set([])\n",
    "\n",
    "        g_scores = {}\n",
    "        g_scores[start] = 0\n",
    "\n",
    "        parents = {}\n",
    "        parents[start] = start\n",
    "\n",
    "        while len(open_lst) > 0:\n",
