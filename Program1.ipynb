    "from collections import deque\n",
    "\n",
    "class Graph:\n",
    "    def __init__(self, adjac_lis):\n",
    "        # Correcting attribute name from adjac lis to adjac_lis\n",
    "        self.adjac_lis = adjac_lis\n",
    "\n",
    "    def get_neighbors(self, v):\n",
    "        return self.adjac_lis.get(v, [])  # Use .get() to handle cases where a node might not have an entry\n",
    "\n",
    "    # This is a heuristic function which is having equal values for all nodes\n",
    "    def h(self, n):\n",
    "        # Correcting dictionary definition syntax, using a placeholder return for nodes not specified\n",
    "        H = {'A': 1, 'C': 1, 'B': 1, 'D': 1}\n",
    "        return H.get(n, 0)\n",
    "\n",
    "    def a_star_algorithm(self, start, stop):\n",
    "        # In this open_lst is a list of nodes which have been visited, but who's\n",
    "        # neighbours haven't all been always inspected, It starts off with the start\n",
    "        # node\n",
    "        # And closed_lst is a list of nodes which have been visited\n",
    "        # and who's neighbors have been always inspected\n",
    "        open_lst = set([start])\n",
    "        closed_lst = set([])\n",
    "\n",
    "        # poo has present distances from start to all other nodes\n",
    "        # the default value is infinity\n",
    "        # Correcting attribute name from poo to g_scores\n",
    "        g_scores = {}\n",
    "        g_scores[start] = 0\n",
    "\n",
    "        # par contains un adjac mapping of all nodes.\n",
    "        # Correcting attribute name from par to parents\n",
    "        parents = {}\n",
    "        parents[start] = start\n",
    "\n",
    "        while len(open_lst) > 0:\n",
    "            n = None\n",
    "            # it will find a node with the lowest value of f()\n",
    "            for v in open_lst:\n",
    "                # Using g_scores[v] + self.h(v) for the f() cost\n",
    "                if n is None or g_scores[v] + self.h(v) < g_scores[n] + self.h(n):\n",
    "                    n = v\n",
    "\n",
    "            if n is None:\n",
    "                print(\"Path does not exist!\")\n",
    "                return None\n",
    "\n",
    "            # if the current node is the stop\n",
    "            # then we start again from start\n",
    "            if n == stop:\n",
    "                reconst_path = []\n",
    "                while parents[n] != n:\n",
    "                    reconst_path.append(n)\n",
    "                    n = parents[n]\n",
    "                reconst_path.append(start)\n",
    "                reconst_path.reverse()\n",
    "                print('Path found: {}'.format(reconst_path))\n",
    "                return reconst_path\n",
    "\n",
    "            # for all the neighbors of the current node do\n",
    "            for (m, weight) in self.get_neighbors(n):\n",
    "                # if the current node is not present in both open_lst and closed_lst\n",
    "                # add it to open_lst and note n as its parent\n",
    "                if m not in open_lst and m not in closed_lst:\n",
    "                    open_lst.add(m)\n",
    "                    parents[m] = n\n",
    "                    g_scores[m] = g_scores[n] + weight\n",
    "                # otherwise, check if it's quicker to first visit n, then m\n",
    "                # and if it is, update parent data and g_scores data\n",
    "                # and if the node was in the closed lst, move it to open lst.\n",
    "                else:\n",
    "                    # Correcting the condition: check if new path is shorter\n",
    "                    if g_scores[m] > g_scores[n] + weight:\n",
    "                        g_scores[m] = g_scores[n] + weight\n",
    "                        parents[m] = n\n",
    "                        if m in closed_lst:\n",
    "                            closed_lst.remove(m)\n",
    "                            open_lst.add(m)\n",
    "\n",
    "            # remove n from the open_lst, and add it to closed_lst\n",
    "            # because all of his neighbors were inspected\n",
    "            open_lst.remove(n)\n",
    "            closed_lst.add(n)\n",
    "\n",
    "        # If loop finishes without finding stop\n",
    "        print(\"Path does not exist!\")\n",
    "        return None\n",
    "\n",
    "# Input Data\n",
    "# Correcting dictionary syntax by adding a comma after the 'B' entry\n",
    "adjac_lis = {\n",
    "    'A': [('B', 1), ('C', 3), ('D', 7)],\n",
    "    'B': [('D', 5)],\n",
    "    'C': [('D', 12)]\n",
    "}\n",
    "\n",
    "graph1 = Graph(adjac_lis)\n",
    "graph1.a_star_algorithm('A', 'D')\n"
   ]
