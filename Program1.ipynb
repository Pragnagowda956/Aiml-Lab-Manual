    "class Graph:\n",
    "    def __init__(self, graph, H, start):\n",
    "        self.graph, self.H, self.start = graph, H, start\n",
    "        self.parent, self.status, self.solution = {}, {}, {}\n",
    "\n",
    "    def computeMinCost(self, v):\n",
    "        options = {}\n",
    "        for nodes in self.graph.get(v, []):\n",
    "            cost = sum(self.H.get(n, 0) + w for n, w in nodes)\n",
    "            options[cost] = [n for n, w in nodes]\n",
    "        \n",
    "        min_cost = min(options.keys()) if options else self.H.get(v, 0)\n",
    "        return min_cost, options.get(min_cost, [])\n",
    "\n",
    "    def aoStar(self, v, backTracking):\n",
    "        print(f\"HEURISTIC: {self.H}\\nSOL GRAPH: {self.solution}\\nNODE: {v}\\n\")\n",
    "        \n",
    "        if self.status.get(v, 0) >= 0:\n",
    "            min_cost, childList = self.computeMinCost(v)\n",
    "            self.H[v], self.status[v] = min_cost, len(childList)\n",
    "            \n",
    "            if all(self.status.get(c) == -1 for c in childList) and childList:\n",
    "                self.status[v], self.solution[v] = -1, childList\n",
    "                if v != self.start: self.aoStar(self.parent[v], True)\n",
    "            \n",
    "            if not backTracking:\n",
    "                for c in childList:\n",
    "                    self.parent[c] = v\n",
    "                    self.status[c] = 0\n",
    "                    self.aoStar(c, False)\n",
    "\n",
    "    def printSol(self):\n",
    "        print(f\"TRAVERSE FROM: {self.start}\\n{'.'*16}\\n{self.solution}\\n{'.'*16}\")\n",
